# Server-side base URL for the backend API (used in server actions, route handlers, ISR fetches)
API_URL=http://localhost:4000

# Client-side base URL for the backend API (used for direct browser calls: orders, sockets, admin)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Google Sign-In (customer site) — same OAuth 2.0 Web application Client ID configured
# as GOOGLE_CLIENT_ID on the backend. Leave blank to hide the "Sign in with Google" button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
